{
  "name": "server",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "start:docker": "pnpm db:deploy && pnpm db:seed:prod && node dist/index.js",
    "db:generate": "prisma generate",
    "db:migrate": "DATABASE_URL=${DATABASE_URL:-file:./dev.db} prisma migrate dev --name init",
    "db:deploy": "PRISMA_SCHEMA_ENGINE_LOG_LEVEL=warn DATABASE_URL=${DATABASE_URL:-file:./dev.db} prisma db push --accept-data-loss",
    "db:seed": "tsx src/scripts/seed.ts",
    "db:seed:prod": "node dist/scripts/seed.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run src/tests/unit",
    "test:integration": "vitest run src/tests/integration"
  },
  "dependencies": {
    "@medical-camp/shared": "workspace:*",
    "@prisma/client": "6.7.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express-rate-limit": "^7.5.0",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "ms": "^2.1.3",
    "nodemailer": "^6.10.1",
    "prisma": "6.7.0",
    "twilio": "^5.8.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/morgan": "^1.9.9",
    "@types/nodemailer": "^6.4.17",
    "@types/ms": "^0.7.34",
    "@types/node": "^22.13.8",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^2.1.8",
    "supertest": "^7.1.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^2.1.8"
  }
}
