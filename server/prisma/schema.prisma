generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum AdminRole {
  SUPER_ADMIN
  STAFF
}

enum RegistrationStatus {
  CONFIRMED
  WAITLISTED
  CANCELLED
}

enum NotificationChannel {
  EMAIL
  SMS
}

enum NotificationEvent {
  REGISTERED
  UPDATED
  CANCELLED
  PROMOTED
  WAITLISTED
}

enum NotificationStatus {
  SENT
  FAILED
  SKIPPED
}

model AdminUser {
  id           Int       @id @default(autoincrement())
  username     String    @unique
  passwordHash String
  role         AdminRole @default(STAFF)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  auditLogs    AuditLog[]
}

model Camp {
  id            Int            @id @default(autoincrement())
  name          String
  date          DateTime
  location      String
  description   String
  capacity      Int
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  registrations Registration[]

  @@index([date])
  @@index([isActive, date])
}

model Registration {
  id               Int                @id @default(autoincrement())
  fullName         String
  age              Int
  contactNumber    String
  email            String?
  campId           Int
  status           RegistrationStatus @default(CONFIRMED)
  confirmationCode String             @unique
  isActive         Boolean            @default(true)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  cancelledAt      DateTime?
  camp             Camp               @relation(fields: [campId], references: [id], onDelete: Restrict)
  notifications    NotificationLog[]

  @@index([campId, status, createdAt])
  @@index([contactNumber, campId])
  @@index([confirmationCode])
}

model NotificationLog {
  id             Int                 @id @default(autoincrement())
  registrationId Int
  channel        NotificationChannel
  event          NotificationEvent
  destination    String?
  status         NotificationStatus
  message        String
  errorMessage   String?
  createdAt      DateTime            @default(now())
  registration   Registration        @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@index([registrationId, createdAt])
  @@index([event, createdAt])
}

model AuditLog {
  id          Int       @id @default(autoincrement())
  actorId     Int?
  actorRole   AdminRole?
  action      String
  entityType  String
  entityId    String
  detailsJson String?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime  @default(now())
  actor       AdminUser? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId, createdAt])
  @@index([action, createdAt])
}
