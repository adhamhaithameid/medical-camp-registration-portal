{
  "name": "medical-camp-registration-portal",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.25.0",
  "scripts": {
    "build": "pnpm --filter @medical-camp/shared build && pnpm --filter server build && pnpm --filter client build",
    "dev": "pnpm db:deploy && pnpm db:seed && pnpm -r --parallel --filter server --filter client dev",
    "dev:server": "pnpm --filter server dev",
    "dev:client": "pnpm --filter client dev",
    "start": "pnpm --filter server start",
    "test": "pnpm test:server && pnpm test:client",
    "test:server": "pnpm --filter server test",
    "test:client": "pnpm --filter client test",
    "test:e2e": "pnpm exec playwright test",
    "db:generate": "pnpm --filter server db:generate",
    "db:migrate": "pnpm --filter server db:migrate",
    "db:deploy": "pnpm --filter server db:deploy",
    "db:seed": "pnpm --filter server db:seed"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.2"
  }
}
